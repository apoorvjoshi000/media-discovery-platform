# ─────────────────────────────────────────────────────────────
# Copy to .env and adjust. Compose reads this file automatically.
# ─────────────────────────────────────────────────────────────

# --- Auth ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_TTL=604800        # seconds (7 days)

# --- Service ports (host) ---
GATEWAY_PORT=8080
CATALOG_PORT=8001
SEARCH_PORT=8002
RECOMMENDER_PORT=8003
WEB_PORT=3000

# --- Datastores (internal compose DNS names) ---
MONGO_URI=mongodb://mongo:27017/media
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
KAFKA_BROKERS=kafka:9092

# --- Search / embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_COLLECTION=movies
EMBEDDING_DIM=384

# --- Rate limiting (token bucket) ---
RATE_LIMIT_CAPACITY=60        # max burst tokens
RATE_LIMIT_REFILL=30          # tokens refilled per second

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAMESPACE=media-platform

# --- Inter-service URLs (gateway → services) ---
CATALOG_URL=http://catalog:8001
SEARCH_URL=http://search:8002
RECOMMENDER_URL=http://recommender:8003
