{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Media Platform — Overview",
  "tags": ["media-platform"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "Gateway request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total[1m]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "sum by (route) (rate(gateway_http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gateway latency p50 / p95 / p99 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(gateway_cache_ops_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(gateway_cache_ops_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate-limited (429/s)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(gateway_rate_limited_total[1m]))", "legendFormat": "429", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka events/s (emitted vs consumed)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(catalog_events_emitted_total[1m]))",
          "legendFormat": "emitted",
          "refId": "A"
        },
        {
          "expr": "sum(rate(recommender_events_consumed_total[1m]))",
          "legendFormat": "consumed",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Search p95 latency by mode (s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_request_duration_seconds_bucket[5m])) by (le, mode))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    }
  ]
}
